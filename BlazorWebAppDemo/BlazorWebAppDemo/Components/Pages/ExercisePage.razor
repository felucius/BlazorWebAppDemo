@page "/exercises"
@using BlazorWebAppDemo.Models
@using BlazorWebAppDemo.Services
@inject ExerciseServices ExerciseServices

<h3>Exercise</h3>

@if (exercises == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Exercise</th>
                <th>Description</th>
                <th>Duration in minutes</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var exercise in exercises)
            {
                <tr>
                    <td>@exercise.Name</td>
                    <td>@exercise.Description</td>
                    <td>@exercise.DurationInMinutes</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Exercise>? exercises;
    protected override async Task OnInitializedAsync()
    {
        exercises = ExerciseServices.getExercises();
    }
}